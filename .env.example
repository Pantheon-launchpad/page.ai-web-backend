NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/pageai

# JWT (generate strong random secrets for production, e.g. `openssl rand -hex 64`)
JWT_ACCESS_SECRET=change_me_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

# CORS — comma-separated list of allowed browser origins (Web client(s)).
# React Native and Electron main-process requests have no Origin header and
# are always allowed regardless of this list (see src/app.js).
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Google Sign-In
GOOGLE_CLIENT_ID=

# Mail (password reset, notifications) — provider-agnostic, not wired to a
# specific vendor in this pass; see services/auth.service.js forgotPassword.
MAIL_FROM=noreply@page.ai
MAIL_PROVIDER_API_KEY=

# Uploads — local | cloudinary (see services/storage/index.js)
UPLOAD_PROVIDER=cloudinary
UPLOAD_BUCKET=pageai-uploads
UPLOAD_PUBLIC_BASE_URL=http://localhost:5000/uploads

# Cloudinary (required if UPLOAD_PROVIDER=cloudinary — get these from your
# Cloudinary dashboard). Uploads go directly client -> Cloudinary using a
# signed URL this API generates; file bytes never pass through this server.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=pageai

# Redis (required for the background worker — email, notifications, AI deck
# generation, scheduled maintenance). If unreachable, the API still works;
# jobs just run inline instead of on a worker process — see src/jobs/queues.js.
REDIS_URL=redis://127.0.0.1:6379
REQUIRE_REDIS=false

# AI provider — local | cloud | gemma-ondevice (only "local" is implemented;
# see services/ai/provider.interface.js for the seam to add a real provider)
AI_PROVIDER=local
AI_DAILY_MESSAGE_LIMIT_FREE=50

BCRYPT_SALT_ROUNDS=10
